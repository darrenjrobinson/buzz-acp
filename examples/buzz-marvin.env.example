# buzz-marvin.env.example
# Copy to a secure location (e.g. ~/.openclaw/secrets/buzz-marvin.env)
# chmod 600 the file — contains private key material
#
# This is the env file for the Marvin agent — routes through OpenClaw.

# ── Nostr Identity ─────────────────────────────────────────────────────────
# Generate with: buzz-admin generate-key
BUZZ_PRIVATE_KEY=<hex private key from buzz-admin generate-key>
BUZZ_PUBLIC_KEY=<hex public key — for reference only, not read by buzz-acp>

# ── Relay ──────────────────────────────────────────────────────────────────
BUZZ_RELAY_URL=ws://localhost:3000
# If relay is on another machine:
# BUZZ_RELAY_URL=ws://192.168.x.x:3000

# ── ACP Agent (buzz-acp-shim) ─────────────────────────────────────────
BUZZ_ACP_AGENT_COMMAND=python3
BUZZ_ACP_AGENT_ARGS=/path/to/buzz-acp-shim.py
BUZZ_ACP_SUBSCRIBE=mentions
BUZZ_ACP_CONTEXT_MESSAGE_LIMIT=12

# ── OpenClaw endpoint (read by buzz-acp-shim) ─────────────────────────
OPENCLAW_URL=http://localhost:18789
OPENCLAW_API_KEY=<your OpenClaw API key if auth is enabled>
OPENCLAW_SESSION_KEY=agent:main:buzz:marvin
OPENCLAW_AGENT_NAME=Marvin

# Optional: inline system prompt override (or use BUZZ_ACP_SYSTEM_PROMPT_FILE)
# OPENCLAW_SYSTEM_PROMPT=You are Marvin...
