# Zaphoid agent — Claude Code agent via native ACP
# Generated by: ~/.local/bin/buzz-admin generate-key

BUZZ_PRIVATE_KEY=<hex-secret-key-from-buzz-admin-generate-key>
BUZZ_RELAY_URL=ws://agenthost.local:3000

# Anthropic API key (Claude calls this directly — no OpenClaw in the path)
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# Owner pubkey — from your Buzz client's NIP-42 auth (buzz-admin list-members shows it)
BUZZ_ACP_AGENT_OWNER=<relay-owner-pubkey-hex>

# Optional: set to debug for verbose output during troubleshooting
# RUST_LOG=buzz_acp=debug
