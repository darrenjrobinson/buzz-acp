# buzz-shadowverse.env.example
# Copy to a secure location (e.g. ~/.openclaw/secrets/buzz-shadowverse.env)
# chmod 600 the file — contains private key material
#
# This is the env file for the Shadowverse agent — routes through Claude Code
# directly to your Anthropic subscription. No OpenClaw involvement.

# ── Nostr Identity ─────────────────────────────────────────────────────────
# Generate with: buzz-admin generate-key
BUZZ_PRIVATE_KEY=<hex private key from buzz-admin generate-key>
BUZZ_PUBLIC_KEY=<hex public key — for reference only>

# ── Relay ──────────────────────────────────────────────────────────────────
BUZZ_RELAY_URL=ws://localhost:3000

# ── ACP Agent (Claude Code — native ACP, no shim needed) ──────────────────
# Claude Code CLI must be installed: https://claude.ai/code
BUZZ_ACP_AGENT_COMMAND=/path/to/claude
# e.g. /home/youruser/.local/bin/claude
BUZZ_ACP_SUBSCRIBE=mentions
BUZZ_ACP_CONTEXT_MESSAGE_LIMIT=12

# System prompt file — defines Shadowverse persona
BUZZ_ACP_SYSTEM_PROMPT_FILE=/path/to/shadowverse-system-prompt.txt

# ── Anthropic API key (used directly by Claude Code) ──────────────────────
# Claude Code reads ANTHROPIC_API_KEY from environment
ANTHROPIC_API_KEY=<your Anthropic API key>
